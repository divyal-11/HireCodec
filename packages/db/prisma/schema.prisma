// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  RECRUITER
  INTERVIEWER
  CANDIDATE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  CODING
  SYSTEM_DESIGN
  BEHAVIORAL
  SQL
}

enum InterviewStatus {
  SCHEDULED
  WAITING
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ExecutionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  SYSTEM_ERROR
}

// ============================================================
// USERS & ORGANIZATIONS
// ============================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  logoUrl   String?  @map("logo_url")
  plan      String   @default("free") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users      User[]
  questions  Question[]
  interviews Interview[]

  @@map("organizations")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String?   @map("org_id") @db.Uuid
  email       String    @unique @db.VarChar(255)
  name        String?   @db.VarChar(255)
  avatarUrl   String?   @map("avatar_url")
  role        UserRole  @default(INTERVIEWER)
  passwordHash String?  @map("password_hash")
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization          Organization?          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  oauthAccounts         OAuthAccount[]
  createdQuestions      Question[]             @relation("QuestionCreator")
  participations        InterviewParticipant[]
  codeSnapshots         CodeSnapshot[]
  executions            Execution[]
  chatMessages          ChatMessage[]
  feedbackGiven         InterviewFeedback[]    @relation("FeedbackReviewer")
  feedbackReceived      InterviewFeedback[]    @relation("FeedbackCandidate")
  sessionEvents         SessionEvent[]

  @@index([orgId, role])
  @@map("users")
}

model OAuthAccount {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  provider     String    @db.VarChar(50)
  providerId   String    @map("provider_id") @db.VarChar(255)
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

// ============================================================
// QUESTIONS & TEST CASES
// ============================================================

model Question {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String?      @map("org_id") @db.Uuid
  createdById   String?      @map("created_by") @db.Uuid
  title         String       @db.VarChar(500)
  slug          String       @unique @db.VarChar(255)
  description   String
  difficulty    Difficulty
  type          QuestionType @default(CODING)
  tags          String[]     @default([])
  timeLimitMs   Int          @default(5000) @map("time_limit_ms")
  memoryLimitMb Int          @default(256) @map("memory_limit_mb")
  isPublic      Boolean      @default(false) @map("is_public")
  isArchived    Boolean      @default(false) @map("is_archived")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization?        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy          User?                @relation("QuestionCreator", fields: [createdById], references: [id])
  starters           QuestionStarter[]
  testCases          TestCase[]
  interviewQuestions InterviewQuestion[]
  codeSessions       CodeSession[]

  @@map("questions")
}

model QuestionStarter {
  id           String  @id @default(uuid()) @db.Uuid
  questionId   String  @map("question_id") @db.Uuid
  language     String  @db.VarChar(50)
  starterCode  String  @map("starter_code")
  solutionCode String? @map("solution_code")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, language])
  @@map("question_starters")
}

model TestCase {
  id             String   @id @default(uuid()) @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  input          String
  expectedOutput String   @map("expected_output")
  isHidden       Boolean  @default(false) @map("is_hidden")
  explanation    String?
  orderIndex     Int      @default(0) @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  question            Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  executionTestResults ExecutionTestResult[]

  @@index([questionId])
  @@map("test_cases")
}

// ============================================================
// INTERVIEWS
// ============================================================

model Interview {
  id              String          @id @default(uuid()) @db.Uuid
  orgId           String?         @map("org_id") @db.Uuid
  title           String?         @db.VarChar(255)
  status          InterviewStatus @default(SCHEDULED)
  scheduledAt     DateTime?       @map("scheduled_at") @db.Timestamptz
  startedAt       DateTime?       @map("started_at") @db.Timestamptz
  endedAt         DateTime?       @map("ended_at") @db.Timestamptz
  durationMinutes Int             @default(60) @map("duration_minutes")
  roomId          String          @unique @map("room_id") @db.VarChar(100)
  inviteToken     String?         @unique @map("invite_token") @db.VarChar(255)
  notes           String?
  recordingUrl    String?         @map("recording_url")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization?          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  participants  InterviewParticipant[]
  questions     InterviewQuestion[]
  codeSessions  CodeSession[]
  chatMessages  ChatMessage[]
  feedback      InterviewFeedback[]
  sessionEvents SessionEvent[]

  @@index([roomId])
  @@index([orgId, status])
  @@map("interviews")
}

model InterviewParticipant {
  id          String    @id @default(uuid()) @db.Uuid
  interviewId String    @map("interview_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  role        String    @db.VarChar(50)
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz
  leftAt      DateTime? @map("left_at") @db.Timestamptz
  guestName   String?   @map("guest_name") @db.VarChar(255)
  guestEmail  String?   @map("guest_email") @db.VarChar(255)

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@map("interview_participants")
}

model InterviewQuestion {
  id          String    @id @default(uuid()) @db.Uuid
  interviewId String    @map("interview_id") @db.Uuid
  questionId  String    @map("question_id") @db.Uuid
  orderIndex  Int       @default(0) @map("order_index")
  assignedAt  DateTime  @default(now()) @map("assigned_at") @db.Timestamptz
  startedAt   DateTime? @map("started_at") @db.Timestamptz
  completedAt DateTime? @map("completed_at") @db.Timestamptz

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id])

  @@map("interview_questions")
}

// ============================================================
// CODE SESSIONS (CRDT STATE + SUBMISSIONS)
// ============================================================

model CodeSession {
  id          String   @id @default(uuid()) @db.Uuid
  interviewId String   @map("interview_id") @db.Uuid
  questionId  String?  @map("question_id") @db.Uuid
  language    String   @default("python") @db.VarChar(50)
  currentCode String   @default("") @map("current_code")
  yjsState    Bytes?   @map("yjs_state")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  interview     Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question      Question?      @relation(fields: [questionId], references: [id])
  snapshots     CodeSnapshot[]
  executions    Execution[]

  @@unique([interviewId, questionId])
  @@map("code_sessions")
}

model CodeSnapshot {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  code       String
  language   String?  @db.VarChar(50)
  createdById String? @map("created_by") @db.Uuid
  snapshotAt DateTime @default(now()) @map("snapshot_at") @db.Timestamptz

  session   CodeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdBy User?       @relation(fields: [createdById], references: [id])

  @@map("code_snapshots")
}

// ============================================================
// EXECUTIONS & RESULTS
// ============================================================

model Execution {
  id            String          @id @default(uuid()) @db.Uuid
  sessionId     String          @map("session_id") @db.Uuid
  submittedById String?         @map("submitted_by") @db.Uuid
  code          String
  language      String          @db.VarChar(50)
  status        ExecutionStatus @default(PENDING)
  stdout        String?
  stderr        String?
  compileOutput String?         @map("compile_output")
  exitCode      Int?            @map("exit_code")
  timeMs        Int?            @map("time_ms")
  memoryKb      Int?            @map("memory_kb")
  isRun         Boolean         @default(true) @map("is_run")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  completedAt   DateTime?       @map("completed_at") @db.Timestamptz

  session     CodeSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  submittedBy User?                 @relation(fields: [submittedById], references: [id])
  testResults ExecutionTestResult[]

  @@index([sessionId])
  @@map("executions")
}

model ExecutionTestResult {
  id           String          @id @default(uuid()) @db.Uuid
  executionId  String          @map("execution_id") @db.Uuid
  testCaseId   String?         @map("test_case_id") @db.Uuid
  status       ExecutionStatus
  actualOutput String?         @map("actual_output")
  timeMs       Int?            @map("time_ms")
  memoryKb     Int?            @map("memory_kb")

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  testCase  TestCase? @relation(fields: [testCaseId], references: [id])

  @@map("execution_test_results")
}

// ============================================================
// CHAT MESSAGES
// ============================================================

model ChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  interviewId String   @map("interview_id") @db.Uuid
  senderId    String?  @map("sender_id") @db.Uuid
  senderName  String?  @map("sender_name") @db.VarChar(255)
  content     String
  messageType String   @default("text") @map("message_type") @db.VarChar(50)
  sentAt      DateTime @default(now()) @map("sent_at") @db.Timestamptz

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  sender    User?     @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

// ============================================================
// FEEDBACK & SCORING
// ============================================================

model InterviewFeedback {
  id                 String   @id @default(uuid()) @db.Uuid
  interviewId        String   @map("interview_id") @db.Uuid
  reviewerId         String?  @map("reviewer_id") @db.Uuid
  candidateId        String?  @map("candidate_id") @db.Uuid
  overallScore       Decimal? @map("overall_score") @db.Decimal(3, 1)
  problemSolving     Int?     @map("problem_solving")
  codeQuality        Int?     @map("code_quality")
  communication      Int?
  technicalKnowledge Int?     @map("technical_knowledge")
  hireDecision       String?  @map("hire_decision") @db.VarChar(50)
  strengths          String?
  improvements       String?
  privateNotes       String?  @map("private_notes")
  submittedAt        DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewer  User?     @relation("FeedbackReviewer", fields: [reviewerId], references: [id])
  candidate User?     @relation("FeedbackCandidate", fields: [candidateId], references: [id])

  @@map("interview_feedback")
}

// ============================================================
// SESSION EVENTS (for replay)
// ============================================================

model SessionEvent {
  id          BigInt   @id @default(autoincrement())
  interviewId String   @map("interview_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(100)
  payload     Json
  actorId     String?  @map("actor_id") @db.Uuid
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorId], references: [id])

  @@index([interviewId, occurredAt])
  @@map("session_events")
}
